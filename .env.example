# =============================================================================
# J.A.R.V.I.S — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your private API keys.
# =============================================================================

# ==============================
# GROQ API (Required for chat)
# ==============================
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Optional fallback keys — if primary fails (rate limit / timeout), these are tried in order
# GROQ_API_KEY_2=your_second_key_here
# GROQ_API_KEY_3=your_third_key_here

# ==============================
# GROQ Models
# ==============================
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BRAIN_MODEL=llama-3.1-8b-instant

# ==============================
# LLM INTELLIGENCE — 4-TIER FALLBACK
# ==============================
# Tier 1: Gemini 2.0 Flash (primary — fast, capable)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Tier 2 & 3: AgentRouter (OpenAI-compatible endpoint)
# Tier 2: GPT-5.5        — auto-fallback when Gemini is rate-limited
# Tier 3: Claude Opus    — complex queries (analyze/design/architecture etc.) + GPT-5.5 fallback
# Tier 4: Groq Llama 70B — always-on emergency backstop (already configured above)
AGENTROUTER_BASE_URL=https://your-agentrouter-endpoint.com/v1
AGENTROUTER_API_KEY=your_agentrouter_api_key_here
DEEP_MODEL=claude-opus-4-8       # Tier 3 model name on AgentRouter
GPT_FAST_MODEL=gpt-5.5           # Tier 2 model name on AgentRouter

# Complexity detection: routes directly to Tier 3 (Claude Opus) if:
#   - message length > 200 chars, OR
#   - message contains: review, analyze, design, architecture, compare, evaluate,
#                       explain why, debug, optimize, refactor



# ==============================
# TAVILY API (Optional — Realtime search)
# ==============================
# Required for web search in Realtime mode. Get key at https://tavily.com
# TAVILY_API_KEY=your_tavily_key_here

# ==============================
# TEXT-TO-SPEECH (Optional)
# ==============================
# Server-side TTS via edge-tts (Microsoft Edge TTS, no API key needed).
TTS_VOICE=en-GB-RyanNeural
TTS_RATE=+22%

# ElevenLabs (Optional — premium voice quality)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here
# ELEVENLABS_STABILITY=0.75
# ELEVENLABS_SIMILARITY=0.88
# ELEVENLABS_STYLE=0.15
# ELEVENLABS_SPEAKER_BOOST=true

VOICE_PROVIDER=edge

# ==============================
# IDENTITY
# ==============================
ASSISTANT_NAME=Jarvis
JARVIS_USER_TITLE=Boss
JARVIS_OWNER_NAME=Your Name Here

# ==============================
# SECURITY (Optional)
# ==============================
# Set a bearer token to protect all API endpoints.
# Once set, all requests must include: Authorization: Bearer <token>
# Leave empty to disable auth (safe for local-only use without the token).
# JARVIS_API_TOKEN=your-secret-token-here

# Simple API Key for /chat endpoint protection (Fix 3)
# If set, requires X-API-Key header in POST /chat requests
# JARVIS_API_KEY=your_simple_api_key_here

# ==============================
# ENVIRONMENT (Fix 4)
# ==============================
# Set to "production" to disable auto-reload and improve performance
# ENV=development

# ==============================
# TELEGRAM BRIDGE (Optional)
# ==============================
TELEGRAM_BOT_TOKEN=        # Get from @BotFather on Telegram
TELEGRAM_OWNER_ID=         # Your personal chat ID — get from @userinfobot

# ==============================
# SCHEDULING & LOCALIZATION
# ==============================
TIMEZONE=Asia/Kolkata
WEATHER_CITY=Bengaluru

# Cloud deployment (Render / Oracle)
GOOGLE_CREDENTIALS_B64=    # base64 of credentials.json — see deploy/google_credentials.py
GOOGLE_TOKEN_B64=          # base64 of database/google_token.json
RENDER_EXTERNAL_URL=       # your Render URL e.g. https://jarvis-xxxx.onrender.com (for self keep-alive)
